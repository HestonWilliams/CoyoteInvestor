# --- Neon PostgreSQL ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Auth ---
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_hex_string
# Generate with: openssl rand -hex 32  (must be 64 hex chars / 32 bytes)
ENCRYPTION_KEY=replace_with_32_byte_hex_string

# --- Cookies / CORS ---
# Comma-separated list; no wildcards in production
CORS_ORIGINS=http://localhost:5000
COOKIE_DOMAIN=
# "true" only in production (requires HTTPS)
COOKIE_SECURE=false

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@coyoteequity.com
BCC_INGEST_WEBHOOK_SECRET=

# --- Cloudflare R2 (Phase 3) ---
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# --- DocuSeal (Phase 3) ---
DOCUSEAL_URL=https://sign.coyoteequity.com
DOCUSEAL_API_KEY=

# --- Gmail OAuth2 ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:5001/api/auth/gmail/callback
GP_GMAIL_ADDRESS=heston@coyoteequity.com

# --- Stripe (Phase 2+, optional) ---
STRIPE_SECRET_KEY=

# --- Server ---
PORT=5001
PUBLIC_URL=http://localhost:5000
